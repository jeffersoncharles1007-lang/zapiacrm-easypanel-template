# =============================================================================
# ZAPIACRM - Variaveis de ambiente (deploy Vercel + Supabase)
#
# Copie para .env.local para rodar localmente. Na Vercel, defina no painel
# (Project Settings -> Environment Variables) ou pela tela do "Deploy".
# =============================================================================

# ===== SUPABASE =====
# PREENCHIDO AUTOMATICAMENTE pela integracao Vercel <-> Supabase.
# (Storage/Integrations -> Supabase). Nao precisa colar a mao no deploy.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=          # = a "anon key" do Supabase
SUPABASE_SERVICE_ROLE_KEY=         # segredo do backend (nunca vai pro cliente/browser)
# Connection string direta (DDL) - usada pelo runner de migrations no build.
POSTGRES_URL_NON_POOLING=

# ===== GOOGLE (Agenda) - COMPARTILHADO =====
# Fornecido por voce (mesmo para todos os clientes).
# CLIENT_ID nao e segredo; CLIENT_SECRET e segredo (cole no deploy).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== EVOLUTION API (WhatsApp) - COMPARTILHADO =====
# Fornecido por voce (mesmo para todos os clientes).
# URL nao e segredo; a KEY e segredo (cole no deploy).
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ===== PAGAMENTO (Paddle) - OPCIONAL =====
# So se o cliente for cobrar via Paddle. Deixe vazio caso contrario.
VITE_PAYMENTS_CLIENT_TOKEN=

# ===== BILLING WEBHOOKS (KIWIFY/CAKTO/PERFECTPAY) - OPCIONAL =====
# Gere cada token no painel do provedor (Apps/Webhooks) e cole aqui.
# Os 3 provedores funcionam nativamente. Se nao for usar, deixe vazio.
KIWIFY_WEBHOOK_TOKEN=
CAKTO_WEBHOOK_TOKEN=
PERFECTPAY_WEBHOOK_TOKEN=

# ===== MAGIC LINK (Autenticacao sem senha) =====
# Configure no Supabase Dashboard:
#   Authentication → URL Configuration
#   Site URL:        https://seu-projeto.vercel.app
#   Redirect URLs:   https://seu-projeto.vercel.app/entrar/callback
#                     https://seu-projeto.vercel.app/entrar
# Authentication → Sign In/Up → Email → "Confirm email" pode ficar ON
# Authentication → Sign In/Up → Email → "Magic link" = habilitado

# ===== CHAVES DE IA - OPCIONAL =====
# O cliente configura depois pelo painel (/master/painel). Pode deixar vazio.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Observacao: as variaveis VITE_* (VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY,
# VITE_SUPABASE_PROJECT_ID, VITE_GOOGLE_CLIENT_ID, VITE_EVOLUTION_API_URL) sao
# geradas automaticamente no build por scripts/vercel-build.mjs a partir das
# variaveis acima. Nao precisa defini-las manualmente.
# ---------------------------------------------------------------------------
